# Copy to .env and fill in. Never commit .env.

# --- Claude ---
ANTHROPIC_API_KEY=

# --- Twilio WhatsApp ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox sender: whatsapp:+14155238886
# Production:    whatsapp:+<your approved business number>
TWILIO_WHATSAPP_FROM=
# Your phone in E.164 format, e.g., whatsapp:+15551234567
USER_WHATSAPP_TO=

# --- Subscription cookies (raw Cookie header string from DevTools) ---
WSJ_COOKIES=
FT_COOKIES=

# --- Gmail OAuth ---
GMAIL_CREDENTIALS_PATH=./config/gmail_credentials.json
GMAIL_TOKEN_PATH=./config/gmail_token.json

# --- Market data APIs ---
ALPHA_VANTAGE_API_KEY=
FRED_API_KEY=
FINNHUB_API_KEY=

# --- Scheduling ---
TIMEZONE=America/Chicago
SCHEDULE_TIME=07:00

# english | mixed | arabic
REPORT_LANGUAGE=english
